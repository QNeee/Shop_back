## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
artifacts/

# .NET Core / ASP.NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Logs
*.log

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# NuGet package restore
project.assets.json
project.nuget.cache

# Publish output
publish/
wwwroot/dist/
wwwroot/lib/

# Entity Framework
*.mdf
*.ldf

# Test results
[Tt]est[Rr]esult*/
[Bb]enchmarkDotNet.Artifacts/

# OS files
.DS_Store
Thumbs.db

# IIS / local settings
applicationhost.config

# Environment files (ОБЕРЕЖНО)
.env
.env.*
appsettings.Development.json

# Secrets
secrets.json

# Docker
docker-compose.override.yml

# Node (якщо є фронт усередині проекту)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
pnpm-lock.yaml
yarn.lock